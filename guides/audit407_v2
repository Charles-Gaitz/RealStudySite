<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Audit 407 — Final Exam Study Guide</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0f0f11;
  --bg2: #17171a;
  --bg3: #1e1e23;
  --bg4: #26262d;
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.14);
  --text: #e8e8ed;
  --text2: #9898a8;
  --text3: #5e5e6e;
  --accent: #c8b8ff;
  --accent2: #8b6cff;
  --gold: #f5c842;
  --gold2: #c89f20;
  --teal: #4ecdc4;
  --coral: #ff6b6b;
  --green: #69db7c;
  --blue: #74c0fc;
  --orange: #ffa94d;
  --radius: 10px;
  --radius-lg: 16px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  line-height: 1.65;
  min-height: 100vh;
}

/* ─── HEADER ─── */
.site-header {
  padding: 3rem 0 2rem;
  text-align: center;
  border-bottom: 1px solid var(--border);
  background: linear-gradient(180deg, #1a1020 0%, var(--bg) 100%);
  position: relative;
  overflow: hidden;
}
.site-header::before {
  content: '';
  position: absolute;
  top: -80px; left: 50%;
  transform: translateX(-50%);
  width: 600px; height: 300px;
  background: radial-gradient(ellipse, rgba(139,108,255,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.header-kicker {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 12px;
}
.header-title {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  font-weight: 400;
  color: var(--text);
  line-height: 1.1;
  margin-bottom: 10px;
}
.header-title em { color: var(--accent); font-style: italic; }
.header-sub {
  font-size: 14px;
  color: var(--text2);
  max-width: 480px;
  margin: 0 auto;
}

/* ─── LAYOUT ─── */
.layout {
  display: flex;
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 1.5rem;
  gap: 0;
}

/* ─── SIDEBAR ─── */
.sidebar {
  width: 220px;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  padding: 2rem 1rem 2rem 0;
  border-right: 1px solid var(--border);
  scrollbar-width: none;
}
.sidebar::-webkit-scrollbar { display: none; }
.sidebar-label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--text3);
  padding: 0 10px;
  margin-bottom: 8px;
  margin-top: 20px;
}
.sidebar-label:first-child { margin-top: 0; }
.nav-btn {
  display: block;
  width: 100%;
  text-align: left;
  padding: 8px 10px;
  border-radius: 8px;
  border: none;
  background: transparent;
  color: var(--text2);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  cursor: pointer;
  transition: all .15s;
  margin-bottom: 2px;
}
.nav-btn:hover { background: var(--bg3); color: var(--text); }
.nav-btn.active {
  background: rgba(139,108,255,0.15);
  color: var(--accent);
  font-weight: 500;
}

/* ─── MAIN CONTENT ─── */
.main {
  flex: 1;
  padding: 2.5rem 2rem 4rem;
  min-width: 0;
}

.section { display: none; }
.section.active { display: block; }

/* ─── TYPOGRAPHY ─── */
h2 {
  font-family: 'Instrument Serif', serif;
  font-size: 2rem;
  font-weight: 400;
  color: var(--text);
  margin-bottom: 6px;
  line-height: 1.2;
}
h3 {
  font-size: 13px;
  font-weight: 600;
  color: var(--text2);
  text-transform: uppercase;
  letter-spacing: .08em;
  margin: 2rem 0 .8rem;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--border);
}
h4 { font-size: 13px; font-weight: 600; color: var(--text); margin: 1rem 0 .4rem; }
.section-intro {
  color: var(--text2);
  font-size: 14px;
  margin-bottom: 1.5rem;
  max-width: 680px;
}

/* ─── CARDS ─── */
.card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1rem 1.1rem;
  margin-bottom: .6rem;
}
.card strong { color: var(--text); font-weight: 600; display: block; margin-bottom: 4px; font-size: 13px; }
.card p, .card li { font-size: 13px; color: var(--text2); }
.card ul { padding-left: 1.1rem; }
.card li { margin-bottom: 2px; }

.card-accent-blue  { border-left: 3px solid var(--blue); }
.card-accent-teal  { border-left: 3px solid var(--teal); }
.card-accent-coral { border-left: 3px solid var(--coral); }
.card-accent-gold  { border-left: 3px solid var(--gold); }
.card-accent-green { border-left: 3px solid var(--green); }
.card-accent-purple{ border-left: 3px solid var(--accent); }
.card-accent-orange{ border-left: 3px solid var(--orange); }

/* ─── CALLOUTS ─── */
.callout {
  background: rgba(116,192,252,0.07);
  border: 1px solid rgba(116,192,252,0.2);
  border-radius: var(--radius);
  padding: 10px 14px;
  margin: 10px 0;
  font-size: 13px;
  color: var(--blue);
}
.callout strong { color: var(--blue); }
.warn {
  background: rgba(255,169,77,0.07);
  border: 1px solid rgba(255,169,77,0.2);
  border-radius: var(--radius);
  padding: 10px 14px;
  margin: 10px 0;
  font-size: 13px;
  color: var(--orange);
}
.danger {
  background: rgba(255,107,107,0.07);
  border: 1px solid rgba(255,107,107,0.2);
  border-radius: var(--radius);
  padding: 10px 14px;
  margin: 10px 0;
  font-size: 13px;
  color: var(--coral);
}
.success {
  background: rgba(105,219,124,0.07);
  border: 1px solid rgba(105,219,124,0.2);
  border-radius: var(--radius);
  padding: 10px 14px;
  margin: 10px 0;
  font-size: 13px;
  color: var(--green);
}

/* ─── GRIDS ─── */
.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 8px 0; }
.grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin: 8px 0; }
@media(max-width: 700px) {
  .grid2, .grid3 { grid-template-columns: 1fr; }
  .layout { flex-direction: column; }
  .sidebar { width: 100%; height: auto; position: relative; border-right: none; border-bottom: 1px solid var(--border); padding: 1rem 0; display: flex; flex-wrap: wrap; gap: 4px; }
  .sidebar-label { display: none; }
  .nav-btn { width: auto; display: inline-block; }
}

/* ─── TABLES ─── */
.tbl-wrap { overflow-x: auto; margin: 8px 0; border-radius: var(--radius); border: 1px solid var(--border); }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th {
  background: var(--bg3);
  text-align: left;
  font-weight: 600;
  color: var(--text2);
  padding: 8px 12px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: .06em;
  white-space: nowrap;
}
td { padding: 8px 12px; color: var(--text2); border-top: 1px solid var(--border); vertical-align: top; }
tr:first-child td { border-top: none; }

/* ─── FORMULA ─── */
.formula {
  font-family: 'DM Mono', monospace;
  font-size: 15px;
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  padding: 12px 16px;
  margin: 10px 0;
  color: var(--accent);
  text-align: center;
}

/* ─── BADGE ─── */
.badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 20px;
  font-family: 'DM Mono', monospace;
  letter-spacing: .04em;
}
.b-green  { background: rgba(105,219,124,.15); color: var(--green); }
.b-gold   { background: rgba(245,200,66,.15);  color: var(--gold); }
.b-red    { background: rgba(255,107,107,.15); color: var(--coral); }
.b-blue   { background: rgba(116,192,252,.15); color: var(--blue); }
.b-purple { background: rgba(139,108,255,.15); color: var(--accent); }

/* ─── FLOW STEPS ─── */
.flow-step { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 14px; }
.step-num {
  width: 26px; height: 26px; border-radius: 50%;
  background: rgba(139,108,255,.2); color: var(--accent);
  font-size: 12px; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 1px;
  font-family: 'DM Mono', monospace;
}
.step-body .title { font-size: 13px; font-weight: 600; color: var(--text); }
.step-body .desc { font-size: 12px; color: var(--text2); margin-top: 2px; }

/* ─── ASSERTION CARDS ─── */
.assertion-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 8px 0; }
.a-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 10px 12px;
}
.a-card .name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 3px; }
.a-card .def  { font-size: 12px; color: var(--text2); margin-bottom: 5px; }
.a-card .tip  { font-size: 11px; color: var(--accent); font-family: 'DM Mono', monospace; }

/* ─── OPINION CARDS ─── */
.op-card { border-radius: var(--radius); padding: 10px 14px; border: 1px solid var(--border); margin-bottom: 6px; }
.op-card .op-title { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
.op-card .op-desc  { font-size: 12px; color: var(--text2); }
.op-green  { border-color: rgba(105,219,124,.3); background: rgba(105,219,124,.06); }
.op-green .op-title  { color: var(--green); }
.op-blue   { border-color: rgba(116,192,252,.3); background: rgba(116,192,252,.06); }
.op-blue .op-title   { color: var(--blue); }
.op-gold   { border-color: rgba(245,200,66,.3);  background: rgba(245,200,66,.06); }
.op-gold .op-title   { color: var(--gold); }
.op-red    { border-color: rgba(255,107,107,.3); background: rgba(255,107,107,.06); }
.op-red .op-title    { color: var(--coral); }
.op-gray   { border-color: var(--border2); background: var(--bg2); }
.op-gray .op-title   { color: var(--text2); }

/* ─── TABS ─── */
.tab-row { display: flex; gap: 4px; margin-bottom: 12px; }
.tab-btn {
  font-size: 12px; padding: 5px 14px;
  border-radius: 20px;
  border: 1px solid var(--border2);
  background: transparent; color: var(--text2);
  cursor: pointer; font-family: 'DM Sans', sans-serif;
  transition: all .15s;
}
.tab-btn:hover { background: var(--bg3); color: var(--text); }
.tab-btn.on { background: rgba(139,108,255,.15); border-color: rgba(139,108,255,.4); color: var(--accent); font-weight: 500; }
.sub-section { display: none; }
.sub-section.on { display: block; }

/* ─── INTERACTIVE CALCULATORS ─── */
.calc-box {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.2rem;
  margin: 10px 0;
}
.calc-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; flex-wrap: wrap; }
.calc-row label { font-size: 13px; color: var(--text2); min-width: 200px; }
.calc-row select, .calc-row input[type=number] {
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 8px;
  color: var(--text);
  font-size: 13px;
  padding: 7px 10px;
  font-family: 'DM Sans', sans-serif;
  outline: none;
  transition: border-color .15s;
}
.calc-row select:focus, .calc-row input[type=number]:focus { border-color: var(--accent2); }
.calc-row select { cursor: pointer; }
.calc-row input[type=number] { width: 160px; }
.calc-result {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;
  margin-top: 12px;
}
.result-cell {
  background: var(--bg3);
  border-radius: 8px; padding: 10px;
  text-align: center;
  border: 1px solid var(--border);
}
.result-cell .label { font-size: 11px; color: var(--text3); margin-bottom: 4px; font-family: 'DM Mono', monospace; text-transform: uppercase; letter-spacing: .05em; }
.result-cell .value { font-size: 20px; font-weight: 600; }

/* ─── QUIZ ─── */
.quiz-block { margin-bottom: 1.8rem; padding-bottom: 1.8rem; border-bottom: 1px solid var(--border); }
.quiz-block:last-child { border-bottom: none; }
.quiz-num { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text3); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .1em; }
.quiz-q { font-size: 14px; color: var(--text); font-weight: 500; margin-bottom: 10px; line-height: 1.5; }
.quiz-opt {
  display: block; width: 100%; text-align: left;
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 8px; padding: 9px 14px;
  margin-bottom: 6px; font-size: 13px;
  color: var(--text2); cursor: pointer;
  transition: all .15s; font-family: 'DM Sans', sans-serif;
}
.quiz-opt:hover { background: var(--bg3); border-color: var(--border2); color: var(--text); }
.quiz-opt.correct { background: rgba(105,219,124,.1); border-color: rgba(105,219,124,.4); color: var(--green); }
.quiz-opt.wrong   { background: rgba(255,107,107,.1); border-color: rgba(255,107,107,.4); color: var(--coral); }
.quiz-explain {
  font-size: 13px; color: var(--text2);
  background: var(--bg3); border-radius: 8px;
  padding: 10px 14px; margin-top: 8px;
  display: none; border-left: 3px solid var(--accent);
  line-height: 1.6;
}
.quiz-score {
  font-family: 'DM Mono', monospace; font-size: 13px;
  color: var(--text3); margin-bottom: 16px;
}
.quiz-score span { color: var(--accent); font-weight: 600; }

/* ─── TIMELINE ─── */
.timeline { position: relative; padding-left: 24px; }
.timeline::before { content: ''; position: absolute; left: 5px; top: 6px; bottom: 6px; width: 2px; background: var(--border2); border-radius: 2px; }
.tl-item { position: relative; margin-bottom: 20px; }
.tl-dot {
  position: absolute; left: -22px; top: 4px;
  width: 12px; height: 12px; border-radius: 50%;
  background: var(--bg3); border: 2px solid var(--border2);
}
.tl-item.highlight .tl-dot { background: var(--accent); border-color: var(--accent2); box-shadow: 0 0 8px rgba(139,108,255,.5); }
.tl-title { font-size: 13px; font-weight: 600; color: var(--text); }
.tl-desc  { font-size: 12px; color: var(--text2); margin-top: 2px; }

/* ─── PROGRESS ─── */
.progress-bar { background: var(--bg3); border-radius: 4px; height: 6px; overflow: hidden; margin-top: 4px; }
.progress-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(--accent2), var(--accent)); transition: width .4s ease; }

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 3px; }

/* ─── FOOTER ─── */
.site-footer {
  text-align: center; padding: 2rem;
  border-top: 1px solid var(--border);
  font-size: 12px; color: var(--text3);
  font-family: 'DM Mono', monospace;
}

.purple-box{background:rgba(200,184,255,0.07);border:1px solid rgba(200,184,255,0.2);border-radius:var(--radius);padding:10px 14px;margin:10px 0;font-size:13px;color:var(--accent);}
.purple-box strong{color:var(--accent);}
ul.std{padding-left:1.2rem;margin-top:6px;}
ul.std li{font-size:13px;color:var(--text2);margin-bottom:4px;}
ul.std li strong{color:var(--text);}
.b-orange{background:rgba(255,169,77,.15);color:var(--orange);}

.purple-box{background:rgba(200,184,255,0.07);border:1px solid rgba(200,184,255,0.2);border-radius:var(--radius);padding:10px 14px;margin:10px 0;font-size:13px;color:var(--accent);}
.purple-box strong{color:var(--accent);}
.quiz-filter{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;}
.filter-btn{font-size:12px;padding:4px 12px;border-radius:14px;border:1px solid var(--border2);background:transparent;color:var(--text2);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;}
.filter-btn:hover{background:var(--bg3);}
.filter-btn.active{background:rgba(139,108,255,.15);border-color:rgba(139,108,255,.4);color:var(--accent);}
.quiz-score-bar{font-family:'DM Mono',monospace;font-size:13px;color:var(--text3);margin-bottom:16px;}
.quiz-score-bar span{color:var(--accent);font-weight:600;}
.b-orange{background:rgba(255,169,77,.15);color:var(--orange);}
</style>
