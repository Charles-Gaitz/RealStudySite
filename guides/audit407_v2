<script>
const questions=[
  {cat:'ch12',q:"Which best describes the relationship between assurance, attestation, and auditing?",opts:["They are three names for the same service","Auditing is the broadest; assurance is the narrowest","Assurance is the broadest; auditing is a subset of attestation, which is a subset of assurance","Attestation is the broadest; auditing and assurance are subsets of it"],ans:2,exp:"Assurance is the broadest category — any independent service that improves information quality for decision makers. Attestation is a subset where specific management assertions are evaluated. Auditing is the most specific — attestation applied to financial statements."},
  {cat:'ch12',q:"Before audits were required by law, what percentage of NYSE firms voluntarily paid for audits?",opts:["42%","62%","82%","100%"],ans:2,exp:"82% of NYSE firms voluntarily paid for audits before legally required (Messier et al. 2014). This demonstrates that demand arises naturally from the principal-agent problem — owners need to monitor managers who have an information advantage."},
  {cat:'ch12',q:"PCAOB inspections for firms auditing MORE than 100 public companies occur:",opts:["Every 3 years","Every 2 years","Annually","Only when triggered by a complaint"],ans:2,exp:"Firms auditing more than 100 public issuers are inspected ANNUALLY by the PCAOB. Firms auditing 100 or fewer issuers are inspected every 3 years."},
  {cat:'ch12',q:"Which procedure provides the MOST reliable audit evidence?",opts:["Inquiries of the client's internal audit staff","Inspection of prenumbered client purchase orders","Inspection of vendor invoices received from client personnel","Inspection of bank statements obtained directly from the financial institution"],ans:3,exp:"Bank statements obtained directly from the bank are external, independent evidence obtained under auditor control — the highest reliability. Inquiry is the weakest form. Internal documents depend on client controls. Vendor invoices routed through the client could have been altered."},
  {cat:'ch34',q:"Analytical procedures are REQUIRED during which audit phase(s)?",opts:["Planning phase only","Final review phase only","Planning AND final review phases","Planning, substantive testing, and final review"],ans:2,exp:"Analytical procedures are REQUIRED in the planning phase (to identify risk areas) AND at the final review. They are OPTIONAL as substantive evidence during the audit."},
  {cat:'ch34',q:"The objective of reviewing credit ratings of a client's customers tests which assertion?",opts:["Completeness","Existence or Occurrence","Valuation and allocation","Rights and obligations"],ans:2,exp:"Credit ratings relate to collectability of receivables — are they valued correctly? This is Valuation. It is not about whether the receivable exists; it is about how much it is worth given the customer's ability to pay."},
  {cat:'ch34',q:"Which best demonstrates professional skepticism?",opts:["Relying more on external vs. internal evidence","Focusing on quantitatively significant items","Critically assessing verbal evidence received from management","Evaluating financial interests held by auditors in the client"],ans:2,exp:"Professional skepticism is a questioning mindset directed at representations made by management. Critically assessing what they tell you verbally is the most direct application. Option A relates to evidence reliability, B to materiality, D to independence."},
  {cat:'ch34',q:"AR = 5%, IR = 1.0, CR = 0.50. What is the required detection risk?",opts:["2.5%","10%","50%","100%"],ans:1,exp:"DR = AR / (IR x CR) = 0.05 / (1.0 x 0.50) = 0.10 = 10%. Low DR means more extensive substantive procedures are required — larger samples, more effective tests, more year-end (vs. interim) testing."},
  {cat:'ch34',q:"Overall materiality = $50M. Tolerable misstatement = 50% of OM. Clearly trivial = 3% of OM. A $2M error is found. What must the auditor do?",opts:["Ignore it — clearly trivial","Accumulate it but no need to communicate","Accumulate it and communicate to the audit committee","Require immediate adjustment or issue qualified opinion"],ans:2,exp:"$2M > clearly trivial (3% x $50M = $1.5M) but < tolerable misstatement ($25M). All misstatements that are NOT clearly trivial must be accumulated and communicated to the audit committee — even if management chooses not to adjust."},
  {cat:'ch34',q:"Which situation INCREASES inherent risk for an account balance?",opts:["Simple, routine transaction type","Strong internal controls over the account","Fair value estimates requiring subjective judgment","Owner-managed company with no debt"],ans:2,exp:"Fair value estimates require subjective judgment and are prone to error or manipulation — this increases inherent risk. Note: inherent risk is assessed WITHOUT regard to controls, so 'strong controls' is irrelevant to IR. Simple transactions and owner-managed structures tend to lower IR."},
  {cat:'modb',q:"Which family member situation would MOST likely impair an auditor's independence?",opts:["A parent's immaterial investment in the audit client","A first cousin's loan from a client","A spouse's employment with the client","A sibling's loan to a director of the client"],ans:2,exp:"A spouse is treated as a covered member equivalent. Their employment with the client in any non-clerical role impairs independence. First cousins are not close relatives under AICPA rules. Siblings are close relatives with more limited restrictions than covered members."},
  {cat:'modb',q:"Which act is FORBIDDEN to CPAs in public practice?",opts:["Selling bookkeeping software to tax clients","Writing a TaxAid newsletter for a publisher","Commission arrangement to receive 4% for recommending software to AUDIT clients","Paying a marketing firm a fixed $1,000 fee per new financial planning client"],ans:2,exp:"Commissions for recommending products or services to ATTEST clients are strictly prohibited (Rule 1.500). Option D is a flat referral fee — always allowed if disclosed. The key distinction: it is the attest relationship that makes Option C forbidden."},
  {cat:'modb',q:"A CPA signs a tax return knowing the client skimmed cash receipts and did not report the income. Which AICPA rule is violated?",opts:["Confidential Client Information Rule","Integrity and Objectivity Rule","Independence Rule","Accounting Principles Rule"],ans:1,exp:"Rule 1.100 — Integrity and Objectivity — requires not misrepresenting facts or subordinating your judgment to others. Signing a return with known false information violates this rule. Independence (1.200) is not the primary issue here since tax work is involved, not attest work."},
  {cat:'modb',q:"CPA Rambo audits Ajax Corp. Independence is NOT impaired if she:",opts:["Owns $1,000 of Ajax stock","Has a husband who owns $1,000 of Ajax stock","Has a sister who is the financial VP of Ajax","Owns $1,000 of Pericles Corp stock, which Ajax owns 40% of and which contributes 3% of Ajax's total assets and income"],ans:3,exp:"Option D: Pericles is not a subsidiary (40% is not control), and contributes only 3% of Ajax — an immaterial indirect investment. Covered members may have immaterial indirect interests. Options A and B are direct/material interests; C is a close relative in a key management position."},
  {cat:'ch5',q:"A material weakness in ICFR requires which opinion on internal controls?",opts:["Qualified ICFR opinion","Adverse ICFR opinion","Disclaimer on the financial statements","Qualified financial statement opinion"],ans:1,exp:"Any material weakness requires an ADVERSE ICFR opinion. There is NO qualified ICFR opinion — it is binary: unqualified (effective) or adverse (not effective). This does NOT automatically change the F/S opinion. A clean F/S opinion alongside an adverse ICFR opinion is possible."},
  {cat:'ch5',q:"Which COSO component is the foundation for all other components?",opts:["Risk Assessment","Control Activities","Control Environment","Monitoring"],ans:2,exp:"The Control Environment is the foundation — it represents the tone at the top, management's commitment to integrity and ethics. Without a strong control environment, the other four components cannot function properly."},
  {cat:'ch5',q:"'All vendor invoices must be matched to a receiving report and PO to ensure billed quantities agree with quantities received at agreed-upon prices.' This control supports which assertion?",opts:["Existence/Occurrence","Completeness","Accuracy/Valuation","Presentation"],ans:2,exp:"Matching invoices to receiving reports and POs verifies that amounts are correct and at the right prices — that is Accuracy/Valuation. It is checking whether the dollar amount of the disbursement is correct."},
  {cat:'ch5',q:"Section 404b (external auditor ICFR opinion) applies to:",opts:["All public companies","Accelerated filers only — market cap greater than $75M","All companies with revenues over $75M","Only large accelerated filers — market cap greater than $700M"],ans:1,exp:"Section 404b requires the external auditor to assess ICFR for 'accelerated filers' — companies with a public float of $75M or more. Non-accelerated filers (under $75M) only need 404a (management's own assessment). 404b = both management AND external auditor opinions."},
  {cat:'ch67',q:"Which operation is incompatible if the cashier receives remittances from customers?",opts:["Cashier prepares the daily deposit","Cashier makes the daily bank deposit","Cashier posts receipts to the AR subsidiary ledger","Cashier endorses the checks"],ans:2,exp:"If the cashier handles cash AND posts to the AR subledger, they can steal cash and cover it up by simply not recording the receipt (lapping fraud). Segregation of duties requires that cash handling and AR recordkeeping be performed by different people."},
  {cat:'ch67',q:"When auditing outstanding checks in the bank reconciliation, the auditor is primarily concerned with which assertion?",opts:["Existence","Completeness","Valuation","Cutoff"],ans:1,exp:"Outstanding checks = recorded by the company but not yet cleared by the bank. The concern is Completeness — are ALL outstanding checks included in the reconciliation? An unrecorded outstanding check would understate liabilities. Auditor traces from the cutoff bank statement to the disbursements journal."},
  {cat:'ch67',q:"An auditor selects a sample of shipping documents and traces them forward to the sales journal. This tests:",opts:["Existence of recorded sales","Completeness of recorded sales","Valuation of recorded sales","Cutoff of recorded sales"],ans:1,exp:"Tracing (source document to report) tests Completeness. Starting from shipping docs (proof a transaction happened) and following forward to the journal checks whether all shipments were actually recorded as revenue."},
  {cat:'ch67',q:"An unexplained decrease in the gross profit to sales ratio may suggest:",opts:["Unrecorded purchases","Unrecorded sales","Merchandise purchases charged to SG&A","Fictitious sales"],ans:1,exp:"GP/Sales = (Revenue - COGS) / Revenue. Unrecorded sales means revenue is understated — both the numerator and denominator decrease, but proportionally the ratio drops. Fictitious sales would inflate revenue and INCREASE the ratio. Unrecorded purchases would understate COGS, which would INCREASE the ratio."},
  {cat:'mode',q:"Which sampling risk is an EFFECTIVENESS concern (not merely an efficiency concern)?",opts:["Risk of incorrect rejection (Type I)","Risk of underreliance on controls","Risk of incorrect acceptance (Type II)","Nonsampling risk"],ans:2,exp:"Risk of incorrect acceptance (Type II) means your sample concludes everything is fine when a material misstatement actually exists — you issue a wrong opinion. That is an effectiveness failure. Type I errors (incorrect rejection / underreliance) are efficiency losses — extra unnecessary work, but the final opinion is still correct."},
  {cat:'mode',q:"Attribute sampling: risk of overreliance = 5%, sample size = 30, deviations found = 3. ULRD from the evaluation table = 23.9%, TRD = 15%. The auditor's conclusion is:",opts:["Rely on controls as planned — ULRD is less than or equal to TRD","Reduce planned reliance on controls — ULRD exceeds TRD","The sample is too small to draw any conclusion","Results are inconclusive because deviations exceed the EPDR"],ans:1,exp:"ULRD (23.9%) > TRD (15%) means the auditor CANNOT rely on the control as planned. They must reduce reliance, which means increasing control risk and therefore reducing detection risk by doing more extensive substantive work. This is the 'overreliance risk' scenario."},
  {cat:'mode',q:"All else equal, which change would INCREASE required sample size for an attribute test?",opts:["Increasing the tolerable rate of deviation from 8% to 10%","Decreasing the expected deviation rate from 2% to 1%","Increasing the desired risk of overreliance from 5% to 10%","Decreasing the tolerable rate of deviation from 10% to 8%"],ans:3,exp:"Decreasing TRD (stricter standard = more precision required) increases the sample size needed — inverse relationship. Increasing TRD (A), decreasing EPDR (B), and accepting more sampling risk (C) all REDUCE the required sample size."},
  {cat:'ch1112',q:"Which is a Type I subsequent event requiring ADJUSTMENT to the financial statements?",opts:["Sale of new stock for $500K in January","Settlement of a February 15 personal injury lawsuit for $10K","Settlement in February of litigation that had been estimated at $12K at year-end, now settled for $100K","Storm damage of $1M to buildings on March 1"],ans:2,exp:"Option C provides new evidence about a condition (the lawsuit) that EXISTED at December 31. Type I events clarify conditions that already existed at year-end — the F/S must be adjusted. The others are new post-year-end events (Type II = disclose only)."},
  {cat:'ch1112',q:"A company has not capitalized material finance leases (GAAP departure). The departure is both material and pervasive. What opinion results?",opts:["Qualified opinion","Adverse opinion","Disclaimer of opinion","Unmodified opinion with an explanatory paragraph"],ans:1,exp:"GAAP departure + material + pervasive = Adverse opinion. The decision tree: material? Yes. Pervasive? Yes. Therefore Adverse. A qualified opinion is for material but NOT pervasive GAAP departures."},
  {cat:'ch1112',q:"Can an accelerated filer receive a clean F/S opinion and an adverse ICFR opinion simultaneously?",opts:["No — the opinions must always be consistent","Yes — a material weakness indicates risk but does not guarantee an actual misstatement exists in the F/S","Only if the material weakness was discovered after year-end","Only for nonpublic companies"],ans:1,exp:"YES. A material weakness means there is a reasonable POSSIBILITY that a material misstatement will not be prevented or detected — not that a misstatement actually exists. If the auditor finds no actual material misstatement in the F/S, the F/S opinion can still be unmodified (clean). Peloton's June 2022 10-K is a real example of this."},
];

let answered=0,correct=0,visibleQuestions=questions;

function buildQuiz(qs){
  const c=document.getElementById("quiz-container");
  c.innerHTML="";
  document.getElementById("score-display").textContent="0";
  document.getElementById("total-display").textContent="0";
  answered=0;correct=0;
  qs.forEach((q,i)=>{
    const div=document.createElement("div");
    div.className="quiz-block";
    div.innerHTML=`<div class="quiz-num">Question ${i+1} of ${qs.length} &middot; ${catLabel(q.cat)}</div><div class="quiz-q">${q.q}</div>${q.opts.map((o,j)=>`<button class="quiz-opt" onclick="answer(this,${i},${j})">${String.fromCharCode(65+j)}. ${o}</button>`).join("")}<div class="quiz-explain" id="exp-${i}">${q.exp}</div>`;
    c.appendChild(div);
  });
}

function catLabel(c){
  const m={ch12:"Ch 1-2",ch34:"Ch 3-4",modb:"Module B",ch5:"Ch 5",ch67:"Ch 6-7",mode:"Module E",ch1112:"Ch 11-12"};
  return m[c]||c;
}

function answer(btn,qi,oi){
  const block=btn.parentElement;
  if(block.querySelector(".correct")||block.querySelector(".wrong"))return;
  answered++;
  const q=visibleQuestions[qi];
  if(oi===q.ans){btn.classList.add("correct");correct++;}
  else{btn.classList.add("wrong");block.querySelectorAll(".quiz-opt")[q.ans].classList.add("correct");}
  document.getElementById("exp-"+qi).style.display="block";
  document.getElementById("score-display").textContent=correct;
  document.getElementById("total-display").textContent=answered;
}

function filterQuiz(cat,btn){
  document.querySelectorAll(".filter-btn").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  visibleQuestions=cat==="all"?questions:questions.filter(q=>q.cat===cat);
  buildQuiz(visibleQuestions);
}

function show(id,btn){
  document.querySelectorAll(".section").forEach(s=>s.classList.remove("active"));
  document.querySelectorAll(".nav-btn").forEach(b=>b.classList.remove("active"));
  document.getElementById("s-"+id).classList.add("active");
  if(btn)btn.classList.add("active");
  window.scrollTo(0,0);
}

function showTab(id,group){
  document.querySelectorAll(".sub-section").forEach(s=>{if(s.id.endsWith("-tab"))s.classList.remove("on");});
  document.querySelectorAll(".tab-btn").forEach(b=>b.classList.remove("on"));
  document.getElementById(id).classList.add("on");
  event.target.classList.add("on");
}

function calcRisk(){
  const ar=parseFloat(document.getElementById("ar-val").value);
  const ir=parseFloat(document.getElementById("ir-val").value);
  const cr=parseFloat(document.getElementById("cr-val").value);
  const dr=ar/(ir*cr);
  const rmm=ir*cr;
  const drPct=Math.round(dr*1000)/10;
  const rmmPct=Math.round(rmm*1000)/10;
  const drColor=dr<=0.1?"#ff6b6b":dr<=0.25?"#ffa94d":dr<=0.5?"#f5c842":"#69db7c";
  const workLevel=dr<=0.1?"Extensive substantive work needed":dr<=0.25?"Significant substantive work":dr<=0.5?"Moderate work needed":"Lighter substantive testing ok";
  document.getElementById("risk-result").innerHTML=`<div class="result-cell"><div class="label">RMM (IR x CR)</div><div class="value" style="color:var(--orange)">${rmmPct}%</div></div><div class="result-cell"><div class="label">Required DR</div><div class="value" style="color:${drColor}">${drPct}%</div></div><div class="result-cell"><div class="label">Implication</div><div class="value" style="font-size:12px;color:var(--text2);font-weight:400;margin-top:4px;">${workLevel}</div></div>`;
}

function calcMat(){
  const ibt=parseFloat(document.getElementById("ibt").value)||0;
  const omPct=parseFloat(document.getElementById("om-pct").value)||5;
  const tmPct=parseFloat(document.getElementById("tm-pct").value)||50;
  const ctPct=parseFloat(document.getElementById("ct-pct").value)||3;
  const om=ibt*omPct/100;const tm=om*tmPct/100;const ct=om*ctPct/100;
  const fmt=n=>"$"+Math.round(n).toLocaleString();
  document.getElementById("mat-result").innerHTML=`<div class="result-cell"><div class="label">Overall Materiality</div><div class="value" style="color:var(--text)">${fmt(om)}</div></div><div class="result-cell"><div class="label">Tolerable Misstatement</div><div class="value" style="color:var(--blue)">${fmt(tm)}</div></div><div class="result-cell"><div class="label">Clearly Trivial</div><div class="value" style="color:var(--gold)">${fmt(ct)}</div></div>`;
}

visibleQuestions=questions;
buildQuiz(questions);
window.addEventListener("load",()=>{calcRisk();calcMat();});
if(document.getElementById("ar-val")){calcRisk();calcMat();}
</script>

